
model Project {
  id           String      @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  title        String      // e.g., "SkillBridge" [cite: 75]
  description  String      @db.Text
  content      String      @db.Text // Rich-text markdown content for a detailed project page
  type         ProjectType
  thumbnailUrl String
  liveUrl      String? 
  githubUrl    String?
  tags         String[]    // e.g., ["Next.js", "Prisma", "Stripe"] [cite: 87, 89, 95]
  featured     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}